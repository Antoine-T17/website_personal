# obtenir mot de passe depuis env ou colonne password
pw <- ""
if (nzchar(df$env[i])) pw <- Sys.getenv(df$env[i], "")
if (!nzchar(pw) && nzchar(df$password[i])) pw <- df$password[i]
if (!nzchar(pw)) {
res$status[i] <- "no_password"; next
}
encrypt_links <- as.logical(df$encrypt_links[i])
out_spec <- ifelse(nzchar(df$out[i]), df$out[i], NA)
# exécuter
tryCatch({
if (isTRUE(encrypt_links)) {
out_path <- protect_html_with_links(src, pw, encrypt_links = TRUE)
} else {
out_path <- protect_html_one(src, pw, out = out_spec)
}
res$out[i] <- out_path
res$status[i] <- "ok"
}, error = function(e) {
res$out[i] <- NA
res$status[i] <- paste0("error: ", conditionMessage(e))
})
}
write.csv(res, result_csv, row.names = FALSE)
message("Batch finished. Résultats écrits dans: ", result_csv)
invisible(res)
}
message("Script chargé — utilise protect_html_one(), protect_html_with_links() ou protect_html_from_map().")
protect_html_one("docs/posts/opur6/project.html", password = "opur6")
protect_html_one("docs/posts/opur_6/project.html", password = "MonMDP_OPUR6")
protect_html_one("docs/posts/opur_6/protocoles/protocole_analyses_écotoxicologiques/Protocole_analyses_écotoxicologiques.html", password = "MonMDP_OPUR6")
protect_html_one("docs/posts/opur_6/project.html", password = "MonMDP_OPUR6")
# ================== PROTECTEUR HTML PAR-FICHIER (R pur, sans téléchargement) ==================
# Coller ce bloc dans la Console RStudio (depuis la racine du repo).
# Usage résumé :
#  - protect_html_one(src, password) : chiffre une page en src.protected.html
#  - protect_html_with_links(src, password, encrypt_links=TRUE) : chiffre la page et ses liens locaux
#  - protect_html_from_map("protect_map.csv") : batch via CSV local (NE PAS COMMIT)
# --- dépendance ---
if (!requireNamespace("openssl", quietly = TRUE)) install.packages("openssl")
library(openssl)
# --- .gitignore safety ---
gi <- ".gitignore"
to_ignore <- c("protect_map.csv", ".Renviron", "protect_map_result.csv")
old <- if (file.exists(gi)) readLines(gi, warn = FALSE) else character(0)
add <- setdiff(to_ignore, old)
if (length(add)) {
writeLines(c(old, add), gi)
message(".gitignore mis à jour (ajouté): ", paste(add, collapse = ", "))
}
# ----------------- protect_html_one -----------------
protect_html_one <- function(src, password, out = NULL, overwrite = TRUE) {
if (!file.exists(src)) stop("Source introuvable: ", src)
if (!nzchar(password)) stop("Mot de passe vide pour : ", src)
# lire binaire
html_raw <- readBin(src, what = "raw", n = file.info(src)$size)
# clé & IV
key_raw <- sha256(charToRaw(password))
iv_raw  <- rand_bytes(16)
# chiffrage
cipher_raw <- aes_cbc_encrypt(html_raw, key = key_raw, iv = iv_raw)
iv_hex     <- paste0(sprintf("%02x", as.integer(iv_raw)), collapse = "")
cipher_b64 <- base64_encode(cipher_raw)
# sortie par défaut
if (is.null(out) || !nzchar(out)) {
base <- tools::file_path_sans_ext(basename(src))
out <- file.path(dirname(src), paste0(base, ".protected.html"))
}
if (file.exists(out) && !overwrite) {
message("Protected exists and overwrite=FALSE, skipping: ", out)
return(normalizePath(out, winslash = "/", mustWork = FALSE))
}
# build wrapper as vector of lines to avoid quoting issues
wrapper_lines <- c(
"<!doctype html>",
"<meta charset=\"utf-8\">",
"<title>Protected page</title>",
"<style>",
"body{font-family:system-ui,Arial;padding:2rem;background:#f7f7f9;color:#222}",
".box{max-width:760px;margin:4rem auto;padding:2rem;background:#fff;border-radius:8px;box-shadow:0 6px 24px rgba(0,0,0,0.08)}",
"input[type=\"password\"]{width:100%%;padding:0.6rem;margin-top:0.5rem;font-size:1rem}",   # note: %% pour sprintf
"button{margin-top:1rem;padding:0.6rem 1rem;font-size:1rem}",
".hint{margin-top:1rem;color:#666;font-size:0.9rem}",
"</style>",
"<div class=\"box\">",
"<h2>Protected page</h2>",
"<p>Enter the password to view this page.</p>",
"<input id=\"pw\" type=\"password\" placeholder=\"Password\" />",
"<button id=\"go\">Open</button>",
"<div id=\"err\" style=\"color:#b00020;margin-top:0.8rem\"></div>",
"<p class=\"hint\">If the page does not open, try allowing pop-ups or use a modern browser.</p>",
"</div>",
"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js\"></script>",
"<script>",
"(function(){",
"  var iv_hex = \"%s\";",                # placeholder 1
"  var cipher_b64 = \"%s\";",            # placeholder 2
"  function hexToWA(h){ return CryptoJS.enc.Hex.parse(h); }",
"  function b64ToWA(b){ return CryptoJS.enc.Base64.parse(b); }",
"  function openInline(html){ document.open(); document.write(html); document.close(); }",
"  document.getElementById(\"go\").addEventListener(\"click\", function(){",
"    var pw = document.getElementById(\"pw\").value;",
"    if(!pw){ document.getElementById(\"err\").textContent = \"Password empty\"; return; }",
"    try{",
"      var key = CryptoJS.enc.Hex.parse(CryptoJS.SHA256(pw).toString());",
"      var iv  = hexToWA(iv_hex);",
"      var ct  = b64ToWA(cipher_b64);",
"      var dec = CryptoJS.AES.decrypt({ciphertext: ct}, key, { iv: iv, mode: CryptoJS.mode.CBC, padding: CryptoJS.pad.Pkcs7 });",
"      var txt = dec.toString(CryptoJS.enc.Utf8);",
"      if(!txt){ document.getElementById(\"err\").textContent = \"Wrong password or decryption failed.\"; return; }",
"      openInline(txt);",
"    } catch(e){ document.getElementById(\"err\").textContent = \"Decryption error\"; }",
"  });",
"  document.getElementById(\"pw\").addEventListener(\"keydown\", function(e){ if(e.key === 'Enter') document.getElementById('go').click(); });",
"})();",
"</script>"
)
wrapper <- paste(wrapper_lines, collapse = "\n")
wrapper <- sprintf(wrapper, iv_hex, cipher_b64)   # inject iv & cipher
# écrire en binaire
dir.create(dirname(out), recursive = TRUE, showWarnings = FALSE)
con <- file(out, open = "wb"); on.exit(try(close(con), silent = TRUE), add = TRUE)
writeBin(charToRaw(wrapper), con); close(con)
normalizePath(out, winslash = "/", mustWork = FALSE)
}
# ----------------- helper relpath -----------------
relpath <- function(from_dir, to_file) {
from <- normalizePath(from_dir, winslash = "/", mustWork = TRUE)
to   <- normalizePath(to_file, winslash = "/", mustWork = TRUE)
fparts <- strsplit(from, "/", fixed = TRUE)[[1]]
tparts <- strsplit(to, "/", fixed = TRUE)[[1]]
common <- 0L
maxi <- min(length(fparts), length(tparts))
for (i in seq_len(maxi)) {
if (fparts[i] == tparts[i]) common <- common + 1L else break
}
up <- rep("..", length(fparts) - common)
down <- if (common < length(tparts)) tparts[(common + 1L):length(tparts)] else character(0)
parts <- c(up, down)
if (length(parts) == 0) "." else do.call(file.path, as.list(parts))
}
# ----------------- protect_html_with_links -----------------
protect_html_with_links <- function(src, password, encrypt_links = TRUE, visited = character(0)) {
if (!file.exists(src)) stop("Source introuvable : ", src)
src_key <- normalizePath(src, winslash = "/", mustWork = TRUE)
if (src_key %in% visited) { message("Déjà traité : ", src); return(invisible(NULL)) }
visited <- c(visited, src_key)
src_dir <- dirname(src)
# lire texte (utf-8/binaire safe)
txt <- readChar(src, file.info(src)$size, useBytes = TRUE)
# chercher href="...*.html" et href='...*.html' (exclut http(s):// et root /)
pattern <- "(?i)href\\s*=\\s*([\"'])([^\"']+?\\.html(?:#[^\"']*)?)\\1"
matches <- gregexpr(pattern, txt, perl = TRUE)
regm <- regmatches(txt, matches)[[1]]
links <- character(0)
if (length(regm) > 0 && nzchar(regm[1])) {
for (m in regm) {
rr <- regexec(pattern, m, perl = TRUE)
cap <- regmatches(m, rr)[[1]]
if (length(cap) >= 3) links <- c(links, cap[3])
}
}
links <- unique(links)
# nettoyage : ne garder que liens locaux (pas http(s)://, pas //, pas mailto:, pas commençant par /)
is_local <- function(u) {
if (!nzchar(u)) return(FALSE)
if (grepl("^[a-z]+:", u, ignore.case = TRUE)) return(FALSE)
if (substr(u, 1, 2) == "//") return(FALSE)
if (substr(u, 1, 1) == "/") return(FALSE)
TRUE
}
local_links <- links[vapply(links, is_local, logical(1))]
if (length(local_links) == 0) {
message("Aucun lien local .html trouvé dans ", src)
} else {
message("Liens locaux trouvés dans ", src, ":\n", paste(local_links, collapse = "\n"))
}
# traiter chaque lien local
for (link in local_links) {
# séparer ancre si présente
anchor <- ""
link_path <- link
if (grepl("#", link, fixed = TRUE)) {
sp <- strsplit(link, "#", fixed = TRUE)[[1]]
link_path <- sp[1]
anchor <- paste0("#", paste(sp[-1], collapse = "#"))
}
target <- normalizePath(file.path(src_dir, link_path), winslash = "/", mustWork = FALSE)
if (!file.exists(target)) { message("Cible non trouvée (skip): ", target); next }
target_prot <- file.path(dirname(target), paste0(tools::file_path_sans_ext(basename(target)), ".protected.html"))
# si encrypt_links -> traiter récursivement
if (encrypt_links) {
protect_html_with_links(target, password, encrypt_links = TRUE, visited = visited)
if (!file.exists(target_prot)) {
# fallback : chiffrer directement la cible
protect_html_one(target, password, out = target_prot)
}
}
# remplacer liens dans txt par chemin relatif vers protected
new_rel <- tryCatch(relpath(src_dir, target_prot), error = function(e) basename(target_prot))
if (nzchar(anchor)) new_rel <- paste0(new_rel, anchor)
# échappement pour gsub
esc <- function(x) gsub("([\\.|\\+|\\*|\\?|\\^|\\$|\\(|\\)|\\[|\\]|\\{|\\}|\\\\|/])", "\\\\\\1", x)
txt <- gsub(paste0("href\\s*=\\s*\"", esc(link), "\""), paste0('href="', new_rel, '"'), txt, perl = TRUE)
txt <- gsub(paste0("href\\s*=\\s*'", esc(link), "'"), paste0("href='", new_rel, "'"), txt, perl = TRUE)
txt <- gsub(paste0("href\\s*=\\s*", esc(link)), paste0('href="', new_rel, '"'), txt, perl = TRUE)
message("Link rewritten: ", link, " -> ", new_rel)
}
# écrire tmp + protéger
tmpf <- tempfile(fileext = ".html")
writeChar(txt, tmpf, eos = NULL)
out_name <- file.path(src_dir, paste0(tools::file_path_sans_ext(basename(src)), ".protected.html"))
protect_html_one(tmpf, password, out = out_name)
message("Protected created: ", out_name)
invisible(normalizePath(out_name, winslash = "/", mustWork = FALSE))
}
# ----------------- protect_html_from_map (batch) -----------------
protect_html_from_map <- function(map_csv = "protect_map.csv", result_csv = "protect_map_result.csv") {
if (!file.exists(map_csv)) {
tmpl <- "file,env,password,out,encrypt_links\n# ex: docs/posts/foo/index.html,PW_FOO,, ,TRUE\n"
writeLines(tmpl, map_csv)
stop("Modèle créé : ", map_csv, " -> édite-le (NE COMMITS PAS) et relance.")
}
df <- read.csv(map_csv, stringsAsFactors = FALSE, na.strings = c("", "NA"))
names(df) <- tolower(names(df))
if (!"file" %in% names(df)) stop("Le CSV doit contenir la colonne 'file'")
if (!"env" %in% names(df)) df$env <- ""
if (!"password" %in% names(df)) df$password <- ""
if (!"out" %in% names(df)) df$out <- ""
if (!"encrypt_links" %in% names(df)) df$encrypt_links <- FALSE
res <- data.frame(file = df$file, out = NA_character_, status = NA_character_, stringsAsFactors = FALSE)
for (i in seq_len(nrow(df))) {
src <- df$file[i]
if (!file.exists(src)) {
res$out[i] <- NA; res$status[i] <- "missing_source"; next
}
# obtenir mot de passe depuis env ou colonne password
pw <- ""
if (nzchar(df$env[i])) pw <- Sys.getenv(df$env[i], "")
if (!nzchar(pw) && nzchar(df$password[i])) pw <- df$password[i]
if (!nzchar(pw)) {
res$status[i] <- "no_password"; next
}
encrypt_links <- as.logical(df$encrypt_links[i])
out_spec <- ifelse(nzchar(df$out[i]), df$out[i], NA)
# exécuter
tryCatch({
if (isTRUE(encrypt_links)) {
out_path <- protect_html_with_links(src, pw, encrypt_links = TRUE)
} else {
out_path <- protect_html_one(src, pw, out = out_spec)
}
res$out[i] <- out_path
res$status[i] <- "ok"
}, error = function(e) {
res$out[i] <- NA
res$status[i] <- paste0("error: ", conditionMessage(e))
})
}
write.csv(res, result_csv, row.names = FALSE)
message("Batch finished. Résultats écrits dans: ", result_csv)
invisible(res)
}
message("Script chargé — utilise protect_html_one(), protect_html_with_links() ou protect_html_from_map().")
protect_html_one("docs/posts/opur_6/project.html", password = "MonMDP_OPUR6")
protect_html_one("docs/posts/opur_6/protocoles/protocole_analyses_écotoxicologiques/Protocole_analyses_écotoxicologiques.html", password = "MonMDP_OPUR6")
protect_html_one("docs/posts/opur_6/project.html", password = "opur6")
protect_html_one("docs/posts/opur_6/protocoles/protocole_analyses_écotoxicologiques/Protocole_analyses_écotoxicologiques.html", password = "opur6")
protect_html_one("docs/posts/rshiny_app_zebrabox/index.html", password = "zebrabox")
protect_html_one("docs/posts/opur_6/project.html", password = "leesu_opur6")
